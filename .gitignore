# .gitignore

# Dependencies
node_modules/
.cache/

# Build
dist/
build/
.next/
__pycache__/
tsconfig.tsbuildinfo

# Environment
.env
.env.local

# Database
*.db
prisma/dev.db

# OS
.DS_Store
*.log

# Memory (private session logs)
memory/*.md
!memory/.gitkeep

# CodeGraph (knowledge graph cache — regenerate with codegraph build)
.codegraph/


# IDE
.idea/
.vscode/
*.swp
*.swo
